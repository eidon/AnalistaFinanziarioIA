{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler", // Sostituisci 'node' con 'Bundler' o 'NodeNext'
    "outDir": "./wwwroot/js/dist",
    "rootDir": "./Scripts",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "sourceMap": true
  },
  "include": [
    "Scripts/**/*.ts"
  ]
}